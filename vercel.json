{
  "builds": [
    {
      "src": "api/generate_aaf.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/generate_aaf",
      "dest": "/api/generate_aaf.py"
    }
  ],
  "headers": [
    {
      "source": "/api/generate_aaf",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://videoplayer-d7p.pages.dev" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, X-API-Key" },
        { "key": "Access-Control-Expose-Headers", "value": "Content-Disposition" }
      ]
    }
  ]
}
